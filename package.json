{
  "name": "@form8ion/vitest",
  "description": "test framework plugin for form8ion",
  "license": "MIT",
  "version": "0.0.0-semantically-released",
  "type": "module",
  "engines": {
    "node": "^18.19.0 || ^20.9.0 || >=22.11.0"
  },
  "author": "Matt Travi <npm@travi.org> (https://matt.travi.org)",
  "repository": "form8ion/vitest",
  "bugs": "https://github.com/form8ion/vitest/issues",
  "homepage": "https://npm.im/@form8ion/vitest",
  "runkitExampleFilename": "./example.js",
  "exports": "./lib/index.mjs",
  "main": "./lib/index.mjs",
  "sideEffects": false,
  "scripts": {
    "pretest": "run-s build",
    "test": "npm-run-all --print-label --parallel lint:* --parallel test:*",
    "pretest:integration:base": "run-s build",
    "lint:gherkin": "gherkin-lint",
    "test:integration": "run-s 'test:integration:base -- --profile noWip'",
    "test:integration:base": "NODE_OPTIONS=--enable-source-maps DEBUG=any cucumber-js test/integration",
    "test:integration:debug": "DEBUG=test run-s test:integration",
    "test:integration:wip": "run-s 'test:integration:base -- --profile wip'",
    "test:integration:wip:debug": "DEBUG=test run-s 'test:integration:wip'",
    "test:integration:focus": "run-s 'test:integration:base -- --profile focus'",
    "build:js": "rollup --config",
    "watch": "run-s 'build:js -- --watch'",
    "clean": "rimraf ./lib",
    "prebuild": "run-s clean",
    "build": "npm-run-all --print-label --parallel build:*",
    "prepack": "run-s build",
    "test:unit": "run-s 'test:unit:base -- --coverage'",
    "test:unit:base": "cross-env NODE_ENV=test DEBUG=any vitest run src/",
    "lint:lockfile": "lockfile-lint",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "run-s 'lint:js -- --fix'",
    "lint:md": "remark . --frail",
    "lint:publish": "publint --strict",
    "generate:md": "remark . --output",
    "pregenerate:md": "run-s build",
    "lint:sensitive": "ban",
    "prepare": "husky install",
    "lint:peer": "npm ls >/dev/null",
    "lint:engines": "ls-engines"
  },
  "files": [
    "example.js",
    "lib/",
    "templates/"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "npm@11.11.0+sha512.f36811c4aae1fde639527368ae44c571d050006a608d67a191f195a801a52637a312d259186254aa3a3799b05335b7390539cf28656d18f0591a1125ba35f973",
  "dependencies": {
    "@form8ion/core": "^4.8.0",
    "@form8ion/javascript-core": "^12.0.0",
    "filedirname": "^3.0.0",
    "tinyglobby": "^0.2.12"
  },
  "devDependencies": {
    "@cucumber/cucumber": "11.3.0",
    "@form8ion/commitlint-config": "2.0.9",
    "@form8ion/eslint-config": "7.0.14",
    "@form8ion/eslint-config-cucumber": "1.4.1",
    "@form8ion/eslint-config-vitest": "1.1.0",
    "@form8ion/remark-lint-preset": "6.0.7",
    "@travi/any": "3.1.3",
    "@vitest/coverage-v8": "4.0.18",
    "ban-sensitive-files": "1.10.11",
    "chai": "6.2.2",
    "cross-env": "10.1.0",
    "cz-conventional-changelog": "3.3.0",
    "gherkin-lint": "4.2.4",
    "husky": "9.1.7",
    "lockfile-lint": "5.0.0",
    "ls-engines": "0.9.4",
    "mock-fs": "5.5.0",
    "npm-run-all2": "8.0.4",
    "publint": "0.3.18",
    "remark-cli": "12.0.1",
    "remark-toc": "9.0.0",
    "remark-usage": "11.0.1",
    "rimraf": "6.1.3",
    "rollup": "4.59.0",
    "rollup-plugin-auto-external": "2.0.0",
    "vitest": "4.0.18",
    "vitest-when": "0.10.0"
  }
}
